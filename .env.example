# Copy to .env and fill with your values. Never commit .env.
# Vite uses VITE_ prefix for client-exposed variables.

VITE_API_URL=http://localhost:5000/api
VITE_BACKEND_URL=http://localhost:5000

VITE_RAZORPAY_KEY_ID=

VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=bestofids_unsigned

VITE_WHATSAPP_NUMBER=

VITE_SITE_NAME=Best of IDS
VITE_ADMIN_PATH=/admin
# Optional: Cloudinary base for public assets (e.g. https://res.cloudinary.com/your-cloud/image/upload/bestofids/public)
VITE_ASSETS_BASE=
